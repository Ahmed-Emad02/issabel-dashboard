<%
const words = {
    en: {
        title: "GSM Dongles", subtitle: "Live Status",
        desc: "Real-time chan_dongle device state, signal, SIM number, IMEI and provider",
        id: "ID", state: "State", signal: "Signal", provider: "Provider", model: "Model", number: "SIM Number", imei: "IMEI", imsi: "IMSI", group: "Group",
        free: "Free", notConnected: "Not connected", unavailable: "Unavailable", updated: "Auto refresh every 10 seconds"
    },
    ar: {
        title: "شرائح GSM", subtitle: "الحالة المباشرة",
        desc: "متابعة حالة chan_dongle والإشارة ورقم الشريحة وIMEI والشبكة مباشرة",
        id: "المعرف", state: "الحالة", signal: "الإشارة", provider: "الشبكة", model: "الموديل", number: "رقم الشريحة", imei: "IMEI", imsi: "IMSI", group: "المجموعة",
        free: "جاهز", notConnected: "غير متصل", unavailable: "غير متاح", updated: "تحديث تلقائي كل 10 ثواني"
    }
};
const t = words[currentLang] || words.en;
const isRtl = currentLang === 'ar';
function stateClass(state) {
    if (!state) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/20';
    if (state.toLowerCase() === 'free') return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
    if (state.toLowerCase().includes('not connected')) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/20';
    if (state.toLowerCase().includes('gsm not')) return 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20';
    return 'bg-rose-500/10 text-rose-400 border-rose-500/20';
}
%>
<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= isRtl ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Issabel Analytics - GSM Dongles</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { background-color: #1A0B2E; font-family: 'Cairo', sans-serif; }
        .panel-surface { background-color: #2E113C; border: 1px solid #4A154B; }
        .accent-orange { color: #FF8700; }
        .font-vibrant-display { font-weight: 900; letter-spacing: -0.01em; }
    </style>
</head>
<body class="bg-[#1A0B2E] text-slate-100 flex min-h-screen m-0 p-0">
    <%- include('sidebar') %>
    <main class="flex-1 p-8 min-h-screen">
        <div class="absolute top-6 <%= isRtl ? 'left-8' : 'right-8' %> z-50">
            <select onchange="location.href=window.location.pathname + '?lang=' + this.value" class="bg-[#2E113C] text-white border border-purple-900 rounded-xl px-4 py-2 text-sm font-bold shadow-2xl focus:outline-none focus:border-[#FF8700] cursor-pointer">
                <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English 🇬🇧</option>
                <option value="ar" <%= currentLang === 'ar' ? 'selected' : '' %>>العربية 🇪🇬</option>
            </select>
        </div>

        <header class="mb-8">
            <h2 class="text-3xl font-vibrant-display text-white tracking-tight"><%= t.title %> <span class="accent-orange"><%= t.subtitle %></span></h2>
            <p class="text-xs text-purple-400 font-bold tracking-widest uppercase mt-1"><%= t.desc %></p>
            <p class="text-[11px] text-purple-300 mt-2"><%= t.updated %></p>
        </header>

        <section id="dongleGrid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
            <% (dongles || []).forEach(d => { %>
                <div class="panel-surface rounded-2xl p-5 shadow-xl border border-purple-900/40" id="dongle-card-<%= d.id %>">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <div class="text-2xl font-black text-[#FF8700]"><%= d.id %></div>
                            <div class="text-xs text-purple-300 font-bold uppercase tracking-widest"><%= t.group %>: <%= d.group || '-' %></div>
                        </div>
                        <span class="px-3 py-1 rounded-full text-xs font-black border <%= stateClass(d.state) %>"><%= d.state || '-' %></span>
                    </div>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300"><%= t.signal %></span><span class="font-mono text-white"><%= d.rssi || '0' %></span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300"><%= t.provider %></span><span class="font-bold text-white"><%= d.provider || 'NONE' %></span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300"><%= t.model %></span><span class="font-mono text-white"><%= d.model || '-' %></span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300"><%= t.number %></span><span class="font-mono text-emerald-300"><%= d.number || 'Unknown' %></span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300"><%= t.imei %></span><span class="font-mono text-xs text-white"><%= d.imei || '-' %></span></div>
                        <div class="flex justify-between gap-3"><span class="text-purple-300"><%= t.imsi %></span><span class="font-mono text-xs text-white"><%= d.imsi || '-' %></span></div>
                    </div>
                </div>
            <% }) %>
        </section>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const currentLang = '<%= currentLang %>';
        const labels = <%- JSON.stringify(t) %>;
        const socket = io();
        function stateClass(state) {
            if (!state) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/20';
            state = state.toLowerCase();
            if (state === 'free') return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
            if (state.includes('not connected')) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/20';
            if (state.includes('gsm not')) return 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20';
            return 'bg-rose-500/10 text-rose-400 border-rose-500/20';
        }
        function renderDongles(dongles) {
            const grid = document.getElementById('dongleGrid');
            grid.innerHTML = (dongles || []).map(d => `
                <div class="panel-surface rounded-2xl p-5 shadow-xl border border-purple-900/40" id="dongle-card-${d.id}">
                    <div class="flex items-start justify-between mb-4">
                        <div><div class="text-2xl font-black text-[#FF8700]">${d.id || '-'}</div><div class="text-xs text-purple-300 font-bold uppercase tracking-widest">${labels.group}: ${d.group || '-'}</div></div>
                        <span class="px-3 py-1 rounded-full text-xs font-black border ${stateClass(d.state)}">${d.state || '-'}</span>
                    </div>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300">${labels.signal}</span><span class="font-mono text-white">${d.rssi || '0'}</span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300">${labels.provider}</span><span class="font-bold text-white">${d.provider || 'NONE'}</span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300">${labels.model}</span><span class="font-mono text-white">${d.model || '-'}</span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300">${labels.number}</span><span class="font-mono text-emerald-300">${d.number || 'Unknown'}</span></div>
                        <div class="flex justify-between gap-3 border-b border-purple-900/40 pb-2"><span class="text-purple-300">${labels.imei}</span><span class="font-mono text-xs text-white">${d.imei || '-'}</span></div>
                        <div class="flex justify-between gap-3"><span class="text-purple-300">${labels.imsi}</span><span class="font-mono text-xs text-white">${d.imsi || '-'}</span></div>
                    </div>
                </div>`).join('');
        }
        socket.on('dongleStatus', renderDongles);
        const clockEl = document.getElementById('digitalClock');
        if (clockEl) setInterval(() => { clockEl.textContent = new Date().toTimeString().split(' ')[0]; }, 1000);
    </script>
</body>
</html>
